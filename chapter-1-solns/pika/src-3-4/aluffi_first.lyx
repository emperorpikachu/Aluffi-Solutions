\begin_inset Formula $\Hom_{\catC}(A,C)$
\end_inset

 is nonempty.
 
\end_layout

\begin_layout Standard
Next,
 if there are morphisms 
\begin_inset Formula $f:A\morphism B$
\end_inset

,
 
\begin_inset Formula $g:B\morphism C$
\end_inset

 and 
\begin_inset Formula $h:C\morphism D$
\end_inset

 for objects 
\begin_inset Formula $A,B,C,D\in\Obj(\hat{\mathsf{S}})$
\end_inset

 then the morphism 
\begin_inset Formula $hg=(B,D)$
\end_inset

,
 
\begin_inset Formula $f=(A,B),$
\end_inset

 
